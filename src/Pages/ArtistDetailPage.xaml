<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MusicApp.ViewModels"
             x:Class="MusicApp.Pages.ArtistDetailPage"
             x:DataType="viewmodel:ArtistDetailViewModel">
    <ContentPage.Content>
        <StackLayout>
            <Label Text="{Binding Path=Artist.Name}"></Label>
            <Button Command="{Binding Path=GoBackCommand}"></Button>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>