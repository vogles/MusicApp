<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MusicApp.ViewModels"
             xmlns:models="clr-namespace:MusicApp.Models"
             x:DataType="viewmodel:MyLibraryViewModel"
             x:Class="MusicApp.MyLibraryPage">
		
	<Grid RowDefinitions="100, Auto, *"
	      ColumnDefinitions=".75*, .25*"
	      Padding="10">
		<Image Grid.ColumnSpan="2" 
		       Source="dotnet_bot.png"
		       BackgroundColor="Orange"/>
		
		<CollectionView Grid.Row="2"
		                Grid.ColumnSpan="2"
		                ItemsSource="{Binding Artists}">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="{models:ArtistModel}">
					<Grid ColumnDefinitions="100, *"
					      RowDefinitions=".5*, .5*"
					      HeightRequest="100"
					      Padding="5"
					      Margin="0, 10"
					      BackgroundColor="CornflowerBlue">
						<Grid.GestureRecognizers>
							<TapGestureRecognizer
								Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MyLibraryViewModel}}, Path=ArtistSelectedCommand}"
								CommandParameter="{Binding .}"/>
						</Grid.GestureRecognizers>
						
							
						<Image Grid.RowSpan="2"
						       Source="{Binding ArtistImageUrl}"/>
						<Label Grid.Column="1"
						       Grid.RowSpan="2"
						       Text="{Binding Name}" FontSize="24"/>
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</Grid>
 
</ContentPage>
